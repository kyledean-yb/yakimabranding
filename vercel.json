{
  "buildCommand": "bash scripts/build-landing-page.sh",
  "installCommand": "echo \"Dependencies installed by build script\"",
  "outputDirectory": ".",
  "framework": null,
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/index.html", "destination": "/", "permanent": true },
    { "source": "/services/branding.html", "destination": "/branding", "permanent": true },
    { "source": "/services/branding", "destination": "/branding", "permanent": true },
    { "source": "/services/seo.html", "destination": "/seo", "permanent": true },
    { "source": "/services/seo", "destination": "/seo", "permanent": true },
    { "source": "/services/google-ads.html", "destination": "/google-ads", "permanent": true },
    { "source": "/services/google-ads", "destination": "/google-ads", "permanent": true },
    { "source": "/services/web-design.html", "destination": "/web-design", "permanent": true },
    { "source": "/services/web-design", "destination": "/web-design", "permanent": true },
    { "source": "/services/social-media.html", "destination": "/social-media", "permanent": true },
    { "source": "/services/social-media", "destination": "/social-media", "permanent": true },
    { "source": "/services/press-releases.html", "destination": "/press-releases", "permanent": true },
    { "source": "/services/press-releases", "destination": "/press-releases", "permanent": true },
    { "source": "/services/content-creation.html", "destination": "/content-marketing", "permanent": true },
    { "source": "/services/content-creation", "destination": "/content-marketing", "permanent": true },
    { "source": "/washington-state-sales-tax.html", "destination": "/washington-state-sales-tax-notice", "permanent": true },
    { "source": "/washington-state-sales-tax", "destination": "/washington-state-sales-tax-notice", "permanent": true },
    { "source": "/blog.html", "destination": "/insights", "permanent": true },
    { "source": "/blog", "destination": "/insights", "permanent": true },
    { "source": "/blog/posts/:slug.html", "destination": "/insights/:slug", "permanent": true },
    { "source": "/blog/posts/:slug", "destination": "/insights/:slug", "permanent": true },
    { "source": "/posts/:slug.html", "destination": "/insights/:slug", "permanent": true },
    { "source": "/posts/:slug", "destination": "/insights/:slug", "permanent": true },
    { "source": "/landing-page", "destination": "/phx-hvac", "permanent": true },
    { "source": "/landing-page/", "destination": "/phx-hvac", "permanent": true },
    { "source": "/:path*.html", "destination": "/:path*", "permanent": true }
  ],
  "rewrites": [
    { "source": "/insights/:slug", "destination": "/blog/posts/:slug" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/wp-content/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*).css",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/(.*).webp",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    },
    {
      "source": "/(.*).png",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    }
  ]
}
